# Description: X MultiMedia System
# URL: https://www.xmms.org/
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: gtk1 alsa-lib libvorbis libglvnd xorg-libsm xorg-libxxf86vm

name=xmms
version=1.2.11
release=1
source=(http://slackware.uk/slackware/slackware64-14.2/source/xap/$name/$name-$version.tar.bz2
	xmms.alsa.default.diff
	xmms.gtk.doublesize.diff
	xmms.wmxmms_vis_depth_workaround.diff
	$name.desktop
	$name.png)

build() {
	cd $name-$version

	# Thanks Slackware for the patches
	patch -p1 -i $SRC/xmms.gtk.doublesize.diff
	patch -p0 -i $SRC/xmms.wmxmms_vis_depth_workaround.diff
	patch -p1 -i $SRC/xmms.alsa.default.diff
	
	CC=clang \
	CFLAGS="$CFLAGS -Wno-error=implicit-function-declaration" \
	CXXFLAGS="$CXXFLAGS -Wno-error=implicit-function-declaration" \
	LIBS="-ldl" \
	  ./configure \
	  	--prefix=/usr \
	  	--disable-static \
	  	--disable-simd \
	  	--enable-ipv6 \
	  	--disable-nls
	
	make
	make DESTDIR=$PKG install
	
	# Put man pages to their proper place
	mv $PKG/usr/man $PKG/usr/share
	
	mkdir -p $PKG/usr/share/{applications,pixmaps}
	cat $SRC/$name.desktop > $PKG/usr/share/applications/$name.desktop
	cat $SRC/$name.png > $PKG/usr/share/pixmaps/$name.png
	
	rm -f $PKG/{,usr/}lib/*.la
}
