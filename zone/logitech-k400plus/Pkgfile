# Description: Logitech K400+ - Make F-row keys send normal F1-F12 by default
# URL: /etc/udev/hwdb.d/
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on:

name=logitech-k400plus
version=3.8
release=1
source=(70-$name.hwdb)

build() {
	install -D -m 0644 $SRC/70-$name.hwdb $PKG/etc/udev/hwdb.d/70-$name.hwdb
}
