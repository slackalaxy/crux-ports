# Description: Custom fonts configuration
# URL: https://github.com/slackalaxy/fonts-conf
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: otf-apple-sf-mono ttf-aptos ttf-o365 ttf-sierra ttf-win11 xorg-font-dejavu-ttf xorg-font-terminus

name=fonts-conf
version=9fa803a
release=1
source=(https://github.com/slackalaxy/fonts-conf/archive/$version/$name-9fa803ac72da72d8e48bdf056f375ec4a6e1570e.tar.gz)

build() {
	cd $name-${version}*
	install -D -m644 fonts.conf $PKG/etc/fonts/local.conf
	
	mkdir -p $PKG/etc/profile.d
	echo 'export FREETYPE_PROPERTIES="truetype:interpreter-version=35 cff:no-stem-darkening=0 autofitter:no-stem-darkening=0"' > $PKG/etc/profile.d/fonts-conf.sh
}
