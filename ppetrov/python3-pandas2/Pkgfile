# Description: Powerful data structures for data analysis, time series, and statistics
# URL: https://pandas.pydata.org/docs/getting_started/install.html
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: python3-numpy python3-dateutil python3-tzdata

name=python3-pandas2
version=2.3.3
release=1
source=(https://files.pythonhosted.org/packages/source/p/pandas/pandas-$version.tar.gz)

build() {
    cd pandas-$version

    /usr/bin/pip3 install --isolate --root="$PKG" --ignore-installed --no-deps .

    find $PKG \( -iname "README*" -o \
                 -iname INSTALLER -o \
                 -iname REQUESTED -o \
                 -iname "LICENSE*"   \) -delete

    chmod -R g-w $PKG
}
