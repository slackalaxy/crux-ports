# Description:	Easily test network connectivity
# URL:		https://metacpan.org/dist/Test-RequiresInternet
# Maintainer:	Petar Petrov, slackalaxy at gmail dot com
# Depends on:	perl

name=p5-test-requiresinternet
version=0.05
release=1
source=(http://search.cpan.org/CPAN/authors/id/M/MA/MALLEN/Test-RequiresInternet-${version}.tar.gz)

build() {
	cd Test-RequiresInternet-$version

	# PERL_MM_USE_DEFAULT=1 \
	perl Makefile.PL
	make OPTIMIZE="$CFLAGS" DESTDIR="$PKG" install

	find "$PKG" -depth \
		-type f \( -name .packlist -o -name \*.bs -o -name perllocal.pod \) -delete , \
		-type f -name autosplit.ix \( -exec grep -q '^[[:space:]]*package' {} \; -o -delete \) , \
		-type d -empty -exec rmdir {} +
}
