# Description: simple GTK+ painting program
# URL: https://github.com/wjaguar/mtPaint/
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: gtk3 lcms2 libwebp xorg-libxcomposite xorg-libxcursor xorg-libxinerama

name=mtpaint
version=3.50.14
_commit=8304376e8861a8a603371b0f188db30f9cafdc17
release=1
source=(https://github.com/wjaguar/mtPaint/archive/${_commit:0:7}/$name-${_commit}.tar.gz)
renames=($name-$version.tar.gz)

build() {
	cd mtPaint-${_commit}

	./configure --prefix=/usr \
	gtk3 thread jpeg tiff lcms2 cflags man nojp2 release

	make
	make DESTDIR=$PKG install
}
