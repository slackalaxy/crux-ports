# Description: Miscellaneous utility code used by scverse packages
# URL: https://github.com/scverse/scverse-misc/tags
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: python3-session-info2 python3-pandas2

name=python3-scverse-misc
version=0.0.7
release=1
source=(https://files.pythonhosted.org/packages/source/s/scverse-misc/scverse_misc-$version.tar.gz)

build() {
    cd scverse_misc-$version

    /usr/bin/pip3 install --isolate --root="$PKG" --ignore-installed --no-deps .

    find $PKG \( -iname "README*" -o \
                 -iname INSTALLER -o \
                 -iname REQUESTED -o \
                 -iname "LICENSE*"   \) -delete

    chmod -R g-w $PKG
}
