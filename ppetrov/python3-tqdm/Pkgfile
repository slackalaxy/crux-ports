# Description: Fast, Extensible Progress Meter
# URL: https://github.com/tqdm/tqdm/releases
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: python3-setuptools-scm python3-toml

name=python3-tqdm
version=4.67.1
release=1
source=(https://github.com/tqdm/tqdm/archive/refs/tags/v${version}.tar.gz)
renames=(tqdm-$version)

build() {
  cd ${name#*-}-$version

  /usr/bin/pip3 install --isolate --root="$PKG" --ignore-installed --no-deps .

  find $PKG \( -iname "README*" -o \
               -iname INSTALLER -o \
               -iname REQUESTED -o \
               -iname "LICENSE"   \) -delete
  chmod -R g-w $PKG

}
