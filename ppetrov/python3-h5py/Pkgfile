# Description: Read and write HDF5 files from Python
# URL: https://www.h5py.org/
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: hdf5 liblzf python3-numpy

name=python3-h5py
version=3.16.0
release=1
source=(https://files.pythonhosted.org/packages/source/h/h5py/h5py-$version.tar.gz)

build() {
    cd ${name#*-}-$version

    /usr/bin/pip3 install --isolate --root="$PKG" --ignore-installed --no-deps .

    find $PKG \( -iname "README*" -o \
                 -iname INSTALLER -o \
                 -iname REQUESTED -o \
                 -iname "LICENSE"   \) -delete

    chmod -R g-w $PKG
}
