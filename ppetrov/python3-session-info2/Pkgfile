# Description: Print versions of imported packages.
# URL: https://pypi.org/project/session-info2/
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: python3-build

name=python3-session-info2
version=0.4.1
release=1
source=(https://files.pythonhosted.org/packages/source/s/session-info2/session_info2-$version.tar.gz)

build() {
    cd session_info2-$version

    /usr/bin/pip3 install --isolate --root="$PKG" --ignore-installed --no-deps .

    find $PKG \( -iname "README*" -o \
                 -iname INSTALLER -o \
                 -iname REQUESTED -o \
                 -iname "LICENSE*"   \) -delete

    chmod -R g-w $PKG
}
