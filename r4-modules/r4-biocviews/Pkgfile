name=r4-biocviews
version=1.80.0
release=1
source=(https://bioconductor.org/packages/3.23/bioc/src/contrib/biocViews_${version}.tar.gz)

build() {
	cd biocViews
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
