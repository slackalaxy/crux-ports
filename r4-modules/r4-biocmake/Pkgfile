# Description: R module biocmake
# URL: https://cran.r-project.org/web/packages/biocmake
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-dir-expiry
# Optional: r4-biocstyle r4-knitr r4-rmarkdown r4-testthat

name=r4-biocmake
version=1.3.1
release=1
source=(https://bioconductor.org/packages/3.23/bioc/src/contrib/biocmake_${version}.tar.gz)

build() {
	cd biocmake
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
