# Description: R module metapod
# URL: https://cran.r-project.org/web/packages/metapod
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-rcpp
# Optional: r4-biocstyle r4-knitr r4-rmarkdown r4-testthat

name=r4-metapod
version=1.19.2
release=1
source=(https://bioconductor.org/packages/3.23/bioc/src/contrib/metapod_${version}.tar.gz)

build() {
	cd metapod
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
