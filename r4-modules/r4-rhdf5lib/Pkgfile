# Description: R module Rhdf5lib
# URL: https://cran.r-project.org/web/packages/Rhdf5lib
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: hdf5 r r4-biocmake
# Optional: r4-biocstyle r4-knitr r4-mockery r4-rmarkdown r4-tinytest

name=r4-rhdf5lib
version=1.99.6
release=1
source=(https://bioconductor.org/packages/3.23/bioc/src/contrib/Rhdf5lib_${version}.tar.gz)

build() {
	cd Rhdf5lib
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
