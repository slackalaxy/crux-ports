# Description: R module ProToDeviseR
# URL: https://github.com/Izzilab/protodeviser
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-gggenomes r4-jsonlite r4-dplyr r4-seqinr r4-openxlsx r4-shiny r4-shinybs r4-shinybusy r4-rclipboard r4-shinyjs r4-dt r4-textshaping r4-viridis r4-ragg r4-markdown r4-pkgdown

name=r4-protodeviser
version=01635b2
release=2
source=(https://github.com/izzilab/protodeviser/archive/$version/protodeviser-01635b22151655f87c0708beaed1e40ce40bfa38.tar.gz
	protodeviser_ui.sh protodeviser_ui.desktop protodeviser_ui.png)

build() {
	cd protodeviser-${version}*
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
	
	install -D -m 0755 $SRC/protodeviser_ui.sh $PKG/usr/bin/protodeviser_ui
	
	mkdir -p $PKG/usr/share/{applications,pixmaps}
	cp -a $SRC/protodeviser_ui.desktop $PKG/usr/share/applications
	cp -a $SRC/protodeviser_ui.png $PKG/usr/share/pixmaps
}
