name=r4-pak
version=0.9.5
release=1
source=(https://cloud.r-project.org/src/contrib/pak_${version}.tar.gz)

build() {
	cd pak
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
