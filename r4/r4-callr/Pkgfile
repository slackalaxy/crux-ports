# Description: R-package callr
# URL: https://cran.r-project.org/web/packages/callr
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-otel r4-processx r4-r6
# Optional: r4-asciicast r4-carrier r4-cli r4-otelsdk r4-ps r4-rprojroot r4-spelling r4-testthat r4-withr

name=r4-callr
version=3.8.0
release=1
source=(https://cloud.r-project.org/src/contrib/callr_${version}.tar.gz)

build() {
	cd callr
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
