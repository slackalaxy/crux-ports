# Description: R-package urlchecker
# URL: https://cran.r-project.org/web/packages/urlchecker
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-cli r4-curl r4-gitcreds r4-rlang r4-xml2
# Optional: r4-covr r4-testthat r4-webfakes r4-withr

name=r4-urlchecker
version=2.0.0
release=1
source=(https://cloud.r-project.org/src/contrib/urlchecker_${version}.tar.gz)

build() {
	cd urlchecker
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
