# Description: R-package taxonomizr
# URL: https://cran.r-project.org/web/packages/taxonomizr
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-curl r4-data-table r4-r-utils r4-rsqlite
# Optional: r4-knitr r4-rmarkdown r4-testthat

name=r4-taxonomizr
version=0.11.1
release=1
source=(https://cloud.r-project.org/src/contrib/taxonomizr_${version}.tar.gz)

build() {
	cd taxonomizr
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
