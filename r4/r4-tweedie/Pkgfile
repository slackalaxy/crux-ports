# Description: R-package tweedie
# URL: https://cran.r-project.org/web/packages/tweedie
# Maintainer: Petar Petrov, slackalaxy at gmail dot com
# Depends on: r r4-lifecycle r4-statmod
# Optional: r4-knitr r4-rmarkdown r4-testthat

name=r4-tweedie
version=3.1.0
release=1
source=(https://cloud.r-project.org/src/contrib/tweedie_${version}.tar.gz)

build() {
	export MAKEFLAGS="-j1"
	cd tweedie
	mkdir -p $PKG/usr/lib/R/library
	R CMD INSTALL . -l $PKG/usr/lib/R/library
}
